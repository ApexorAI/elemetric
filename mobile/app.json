{
  "expo": {
    "name": "Elemetric",
    "slug": "elemetric",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app.png",
    "scheme": "elemetric",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07152b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.elemetric.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Elemetric uses the camera to photograph your work for compliance reports.",
        "NSPhotoLibraryUsageDescription": "Elemetric saves compliance photos to your photo library.",
        "NSPhotoLibraryAddUsageDescription": "Elemetric saves compliance photos to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Elemetric uses your location to auto-fill the job site address on checklists.",
        "NSUserNotificationsUsageDescription": "Elemetric notifies you when a job is saved successfully.",
        "UIBackgroundModes": []
      }
    },
    "android": {
      "package": "com.elemetric.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#07152b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/app.png",
          "color": "#f97316",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Elemetric saves compliance photos to your photo library.",
          "cameraPermission": "Elemetric uses the camera to photograph your work for compliance reports."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Elemetric uses your location to auto-fill the job site address on checklists."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#07152b"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
